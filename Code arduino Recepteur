#include <SPI.h>
#include <LoRa.h>

// ================= LORA =================
#define SS 10
#define RST 8
#define DIO0 6

// ================= SETUP =================
void setup() {

  Serial.begin(115200);

  Serial.println("Recepteur LoRa");

  LoRa.setPins(SS, RST, DIO0);

  if (!LoRa.begin(868E6)) {

    Serial.println("Erreur LoRa");
    while (1);
  }

  Serial.println("LoRa OK");
  Serial.println("En attente...");
}

// ================= LOOP =================
void loop() {

  int packetSize = LoRa.parsePacket();

  if (packetSize) {

    String message = "";

    while (LoRa.available()) {
      message += (char)LoRa.read();
    }

    message.trim();

    // Ignore message parasite
    if (message == "DEMANDE_ENTREE") {
      return;
    }

    // ===== Analyse =====
    if (message.indexOf("Pris") >= 0 &&
        message.indexOf("Non") < 0) {

      Serial.println("MEDICAMENT PRIS");
      Serial.println("----------------");
    }

    else if (message.indexOf("Non pris") >= 0 ||
             message.indexOf("NON") >= 0) {

      Serial.println("MEDICAMENT NON PRIS");
      Serial.println("----------------");
    }
  }
}
