#include <SPI.h>
#include <LoRa.h>

// ================= LORA =================
#define SS 10
#define RST 8
#define DIO0 6

void setup() {

  Serial.begin(115200);
  while (!Serial);

  Serial.println("Recepteur LoRa");

  // Initialisation LoRa
  LoRa.setPins(SS, RST, DIO0);

  if (!LoRa.begin(868E6)) {

    Serial.println("Erreur LoRa");
    while (1);
  }

  Serial.println("LoRa OK");
  Serial.println("En attente...");
}

void loop() {

  int packetSize = LoRa.parsePacket();

  if (packetSize) {

    String message = "";

    // Lecture message LoRa
    while (LoRa.available()) {
      message += (char)LoRa.read();
    }

    message.trim();

    // Ignore message parasite UCA21
    if (message == "DEMANDE_ENTREE") {
      return;
    }

    Serial.print("Message recu : ");
    Serial.println(message);

    // ===== Analyse =====
    if (message == "Pris") {

      Serial.println("MEDICAMENT PRIS");
    }

    else if (message == "Non pris") {

      Serial.println("MEDICAMENT NON PRIS");
    }

    else {

      Serial.println("Message inconnu");
    }

    Serial.println("----------------");
  }
}
